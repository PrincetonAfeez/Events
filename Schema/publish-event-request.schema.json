{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./publish-event-request.schema.json",
  "title": "PublishEventRequest",
  "description": "Minimal payload needed to publish a new event through the CLI or bus.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "$ref": "./severity.schema.json"
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "source",
    "event_type",
    "severity",
    "message"
  ],
  "examples": [
    {
      "source": "door-1",
      "event_type": "access_denied",
      "severity": "WARNING",
      "message": "Badge rejected."
    }
  ]
}
